<%- include('partials/header') %>

<div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2 fw-bold text-dark">Gestion des Signalements de Déchets</h1>
</div>

<div class="card card-custom shadow-sm bg-white overflow-hidden">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr class="py-3">
                        <th>ID</th><th>Citoyen</th><th>Commune</th><th>Date</th><th>Média / GPS</th><th>Statut</th><th class="text-end px-4">Actions de Validation</th>
                    </tr>
                </thead>
                <tbody>
                    <% signalements.forEach(function(sig) { %>
                    <tr>
                        <td class="px-3"><strong>#<%= sig.id %></strong></td>
                        <td><%= sig.citoyen %></td>
                        <td><%= sig.commune %></td>
                        <td><%= sig.date %></td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#gpsModal"><i class="bi bi-geo-alt-fill"></i> Voir Média</button>
                        </td>
                        <td>
                            <% if (sig.statut == 'en attente') { %><span class="badge badge-waiting">🟠 En attente</span>
                            <% } else if (sig.statut == 'traité') { %><span class="badge badge-success-eco">🟢 Traité</span>
                            <% } else { %><span class="badge badge-danger-eco">🔴 Rejeté</span><% } %>
                        </td>
                        <td class="text-end px-4">
                            <a href="/gestion-signalements?action=traité&id=<%= sig.id %>&type=signalement" class="btn btn-sm btn-success me-1"><i class="bi bi-check2"></i> Valider</a>
                            <a href="/gestion-signalements?action=rejeté&id=<%= sig.id %>&type=signalement" class="btn btn-sm btn-danger"><i class="bi bi-x-lg"></i> Rejeter</a>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Pop-up d'affichage de la preuve (Photo + Coordonnées GPS) -->
<div class="modal fade" id="gpsModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content" style="border-radius:12px;">
      <div class="modal-header"><h5 class="modal-title fw-bold">Données Médias d'EcoKin</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body text-center">
        <div class="bg-light border p-5 mb-3 rounded text-muted"><i class="bi bi-image fs-1 d-block mb-2"></i> [Preuve photographique du dépôt sauvage à Kinshasa]</div>
        <p class="text-start mb-1"><strong>Coordonnées de géolocalisation :</strong> -4.322415, 15.302144</p>
        <p class="text-start text-muted small">Posté par le citoyen avec validation des capteurs GPS mobiles.</p>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
