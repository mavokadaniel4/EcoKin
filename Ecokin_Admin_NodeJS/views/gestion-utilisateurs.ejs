<%- include('partials/header') %>

<div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2 fw-bold text-dark">Supervision de la Communauté</h1>
</div>

<div class="card card-custom shadow-sm bg-white overflow-hidden">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>ID Citoyen</th><th>Nom Complet</th><th>Email</th><th>Signalements Envoyés</th><th>État du Compte</th><th class="text-end px-4">Sanction</th>
                </tr>
            </thead>
            <tbody>
                <% citoyens.forEach(function(citoyen) { %>
                <tr>
                    <td class="px-3">#<%= citoyen.id %></td>
                    <td><strong><%= citoyen.nom %></strong></td>
                    <td><%= citoyen.email %></td>
                    <td><span class="badge bg-light text-dark border"><%= citoyen.alertes %> alertes envoyées</span></td>
                    <td>
                        <span class="badge <%= citoyen.statut == 'Actif' ? 'bg-success' : 'bg-danger' %>"><%= citoyen.statut %></span>
                    </td>
                    <td class="text-end px-4">
                        <a href="/gestion-utilisateurs?bloquer=<%= citoyen.id %>" class="btn btn-sm btn-warning text-white fw-bold"><i class="bi bi-slash-circle"></i> Restreindre / Bloquer</a>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>

<%- include('partials/footer') %>
