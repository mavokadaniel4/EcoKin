<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EcoKin Admin - Connexion</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light d-flex align-items-center justify-content-center" style="height: 100vh;">
    <div class="card shadow-lg p-4" style="width: 100%; max-width: 420px; border-radius: 12px; border-top: 6px solid #1b5e20;">
        <div class="text-center mb-4">
            <h2 class="fw-bold" style="color: #1b5e20;">EcoKin</h2>
            <p class="text-muted fw-medium">Espace d'Administration Citoyenne</p>
        </div>
        <% if (erreur) { %>
            <div class="alert alert-danger text-center py-2 small fw-bold"><%= erreur %></div>
        <% } %>
        <form method="POST" action="/login">
            <div class="mb-3">
                <label class="form-label fw-semibold text-secondary">Adresse Email Officielle</label>
                <input type="email" name="email" class="form-control py-2" placeholder="admin@ecokin.cd" required>
            </div>
            <div class="mb-4">
                <label class="form-label fw-semibold text-secondary">Mot de passe</label>
                <input type="password" name="password" class="form-control py-2" placeholder="••••••••" required>
            </div>
            <button type="submit" class="btn btn-success w-100 py-2 fw-bold" style="background-color: #1b5e20; border: none;">
                Se connecter au panneau
            </button>
        </form>
    </div>
</body>
</html>
