<%- include('partials/header') %>

<div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2 fw-bold text-dark">Modération des Articles</h1>
</div>

<div class="card card-custom shadow-sm bg-white overflow-hidden">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>ID</th><th>Auteur</th><th>Titre de l'article</th><th>Statut de Visibilité</th><th class="text-end px-4">Actions de Modération</th>
                </tr>
            </thead>
            <tbody>
                <% articles.forEach(function(art) { %>
                <tr>
                    <td class="px-3"><strong>#<%= art.id %></strong></td>
                    <td><%= art.auteur %></td>
                    <td><span class="fw-semibold text-secondary"><%= art.titre %></span></td>
                    <td>
                        <% if (art.statut == 'en attente') { %><span class="badge badge-waiting">🟠 En attente (Masqué)</span>
                        <% } else { %><span class="badge badge-success-eco">🟢 Publié (Visible)</span><% } %>
                    </td>
                    <td class="text-end px-4">
                        <button class="btn btn-sm btn-outline-secondary me-2"><i class="bi bi-file-text"></i> Lire</button>
                        <a href="/moderation-articles?action=publié&id=<%= art.id %>&type=article" class="btn btn-sm btn-success me-1"><i class="bi bi-send-check"></i> Publier</a>
                        <a href="/moderation-articles?action=rejeté&id=<%= art.id %>&type=article" class="btn btn-sm btn-danger"><i class="bi bi-trash"></i></a>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>

<%- include('partials/footer') %>
